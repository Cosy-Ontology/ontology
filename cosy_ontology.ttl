<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#type
rdf:type rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  file:/Users/rodrigocalhau/Documents/VPProjects/null
<file:/Users/rodrigocalhau/Documents/VPProjects/null> rdf:type owl:ObjectProperty .


###  http://purl.org/disc-o#InteractionPartitionedInto
:InteractionPartitionedInto rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf :partitionedInto ;
                            rdfs:domain :Interaction ;
                            rdfs:range gufo:Participation .


###  http://purl.org/disc-o#activation
:activation rdf:type owl:ObjectProperty ;
            rdfs:domain gufo:SituationType ;
            rdfs:range :DispositionType ;
            rdfs:label "activation"@en .


###  http://purl.org/disc-o#arisesFrom
:arisesFrom rdf:type owl:ObjectProperty ;
            rdfs:domain gufo:Aspect ;
            rdfs:range gufo:Aspect .


###  http://purl.org/disc-o#bonding
:bonding rdf:type owl:ObjectProperty ;
         rdfs:domain :ObjectType ;
         rdfs:range :ObjectType ;
         rdfs:label "bonding"@en .


###  http://purl.org/disc-o#bringingAboutOf
:bringingAboutOf rdf:type owl:ObjectProperty ;
                 rdfs:domain gufo:EventType ;
                 rdfs:range gufo:SituationType ;
                 rdfs:label "bringingAboutOf"@en .


###  http://purl.org/disc-o#categoricalBaseOf
:categoricalBaseOf rdf:type owl:ObjectProperty ;
                   rdfs:domain :ObjectQuality ;
                   rdfs:range :Disposition ;
                   rdfs:label "categoricalBaseOf"@en .


###  http://purl.org/disc-o#changes
:changes rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :interactsWithDisposition ;
         rdfs:domain :ChangingDisposition ;
         rdfs:range :Disposition ;
         rdfs:label "changes"@en .


###  http://purl.org/disc-o#characterization
:characterization rdf:type owl:ObjectProperty ;
                  rdfs:domain :DispositionType ;
                  rdfs:range :ObjectType ;
                  rdfs:label "characterization"@en .


###  http://purl.org/disc-o#characterization_1
:characterization_1 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :characterization ;
                    rdfs:domain :DispositionTypeByLevel ;
                    rdfs:range :ObjectTypeByLevel ;
                    rdfs:label "characterizationByLevel"@en .


###  http://purl.org/disc-o#composition
:composition rdf:type owl:ObjectProperty ;
             rdfs:domain :DispositionType ;
             rdfs:range :DispositionType ;
             rdfs:label "compositionDispositionType"@en .


###  http://purl.org/disc-o#composition_1
:composition_1 rdf:type owl:ObjectProperty ;
               rdfs:domain :ObjectTypeByLevel ;
               rdfs:range :ObjectTypeByLevel ;
               rdfs:label "compositionObjectType"@en .


###  http://purl.org/disc-o#constitutesEmergentEvent
:constitutesEmergentEvent rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf gufo:constitutes ;
                          rdfs:domain :ParticularDispositionManifestation ;
                          rdfs:range :EmergentDispositionManifestation ;
                          rdfs:label "constitutesEmergentEvent"@en .


###  http://purl.org/disc-o#disables
:disables rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :interactsWithDisposition ;
          rdfs:domain :DisablingDisposition ;
          rdfs:range :Disposition ;
          rdfs:label "disables"@en .


###  http://purl.org/disc-o#emergence
:emergence rdf:type owl:ObjectProperty ;
           rdfs:domain :DispositionType ;
           rdfs:range :DispositionType ;
           rdfs:label "emergence"@en .


###  http://purl.org/disc-o#emergence_1
:emergence_1 rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :emergence ;
             rdfs:domain :DispositionTypeByLevel ;
             rdfs:range :DispositionTypeByLevel ;
             rdfs:label "emergenceByLevel"@en .


###  http://purl.org/disc-o#emergesFrom
:emergesFrom rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :arisesFrom ;
             rdfs:domain gufo:Aspect ;
             rdfs:range gufo:Aspect ;
             rdfs:label "emergesFrom"@en .


###  http://purl.org/disc-o#enables
:enables rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :interactsWithDisposition ;
         rdfs:domain :EnablingDisposition ;
         rdfs:range :Disposition ;
         rdfs:label "enables"@en .


###  http://purl.org/disc-o#flows
:flows rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :interactsWithDisposition ;
       rdfs:domain :InteractiveDisposition ;
       rdfs:range :InteractiveDisposition .


###  http://purl.org/disc-o#interaction
:interaction rdf:type owl:ObjectProperty ;
             rdfs:domain :InteractiveDispositionRole ;
             rdfs:range :InteractiveDispositionRole ;
             rdfs:label "interactionInteractiveDispositionRole"@en .


###  http://purl.org/disc-o#interaction_1
:interaction_1 rdf:type owl:ObjectProperty ;
               rdfs:domain :InteractiveObjectType ;
               rdfs:range :InteractiveObjectType ;
               rdfs:label "interactionInteractiveObjective"@en .


###  http://purl.org/disc-o#interactsWithDisposition
:interactsWithDisposition rdf:type owl:ObjectProperty ;
                          rdfs:domain :InteractiveDisposition ;
                          rdfs:range :InteractiveDisposition ;
                          rdfs:label "interactsWithDisposition"@en .


###  http://purl.org/disc-o#interactsWith_1
:interactsWith_1 rdf:type owl:ObjectProperty ;
                 rdfs:domain :InteractiveObject ;
                 rdfs:range :InteractiveObject .


###  http://purl.org/disc-o#isAdditionalTo
:isAdditionalTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :interactsWithDisposition ;
                rdfs:domain :AdditionalDisposition ;
                rdfs:range :Disposition ;
                rdfs:label "isAdditionalTo"@en .


###  http://purl.org/disc-o#isDispositionManifestationProperPartOf
:isDispositionManifestationProperPartOf rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf gufo:isEventProperPartOf ;
                                        rdfs:domain :Interaction ,
                                                    :InternalEvent ,
                                                    gufo:Participation ;
                                        rdfs:range :DispositionManifestation .


###  http://purl.org/disc-o#isDispositionProperPartOf
:isDispositionProperPartOf rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf gufo:isAspectProperPartOf ;
                           rdfs:domain :Disposition ;
                           rdfs:range :ComplexDisposition ;
                           rdfs:label "isDispositionProperPartOf"@en .


###  http://purl.org/disc-o#isParticularEventProperPartOf
:isParticularEventProperPartOf rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf gufo:isEventProperPartOf ;
                               rdfs:domain gufo:Event ;
                               rdfs:range :ComplexEvent ;
                               rdfs:label "isParticularEventProperPartOf"@en .


###  http://purl.org/disc-o#isReciprocalTo
:isReciprocalTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :interactsWithDisposition ;
                rdfs:domain :ManifestationPartnerDisposition ;
                rdfs:range :ManifestationPartnerDisposition ;
                rdfs:label "isReciprocalTo"@en .


###  http://purl.org/disc-o#isSubstractiveTo
:isSubstractiveTo rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :interactsWithDisposition ;
                  rdfs:domain :SubtractiveDisposition ;
                  rdfs:range :Disposition ;
                  rdfs:label "isSubtractiveTo"@en .


###  http://purl.org/disc-o#manifestation
:manifestation rdf:type owl:ObjectProperty ;
               rdfs:domain gufo:EventType ;
               rdfs:range :DispositionType ;
               rdfs:label "manifestation"@en .


###  http://purl.org/disc-o#participation
:participation rdf:type owl:ObjectProperty ;
               rdfs:domain :ObjectType ;
               rdfs:range gufo:EventType ;
               rdfs:label "participation"@en .


###  http://purl.org/disc-o#partitionedInto
:partitionedInto rdf:type owl:ObjectProperty ;
                 rdfs:domain gufo:Event ;
                 rdfs:range gufo:Participation .


###  http://purl.org/disc-o#resultsFrom
:resultsFrom rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :arisesFrom ;
             rdfs:domain gufo:Aspect ;
             rdfs:range gufo:Aspect ;
             rdfs:label "resultsFrom"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.com/cosy#MomentType
<http://purl.com/cosy#MomentType> rdf:type owl:Class ;
                                  rdfs:subClassOf gufo:EndurantType .


###  http://purl.org/disc-o#AdditionalDisposition
:AdditionalDisposition rdf:type owl:Class ;
                       rdfs:subClassOf :InteractiveDisposition .


###  http://purl.org/disc-o#AtomicEvent
:AtomicEvent rdf:type owl:Class ;
             rdfs:subClassOf :DispositionManifestation ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                              ] ;
                               owl:someValuesFrom :SimpleDisposition
                             ] .


###  http://purl.org/disc-o#ChangingDisposition
:ChangingDisposition rdf:type owl:Class ;
                     rdfs:subClassOf :InteractiveDisposition .


###  http://purl.org/disc-o#ComplexDisposition
:ComplexDisposition rdf:type owl:Class ;
                    rdfs:subClassOf :Disposition ;
                    owl:disjointWith :SimpleDisposition .


###  http://purl.org/disc-o#ComplexEvent
:ComplexEvent rdf:type owl:Class ;
              rdfs:subClassOf :DispositionManifestation .


###  http://purl.org/disc-o#DisablingDisposition
:DisablingDisposition rdf:type owl:Class ;
                      rdfs:subClassOf :InteractiveDisposition .


###  http://purl.org/disc-o#Disposition
:Disposition rdf:type owl:Class ;
             rdfs:subClassOf gufo:IntrinsicMode ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty gufo:inheresIn ;
                               owl:someValuesFrom gufo:Object
                             ] .


###  http://purl.org/disc-o#DispositionManifestation
:DispositionManifestation rdf:type owl:Class ;
                          rdfs:subClassOf gufo:Event ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                           ] ;
                                            owl:someValuesFrom :Disposition
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                           ] ;
                                            owl:someValuesFrom gufo:Object
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty [ owl:inverseOf gufo:contributedToTrigger
                                                           ] ;
                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass :ManifestationContext
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty gufo:broughtAbout ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass :DispositionOutcome
                                          ] .


###  http://purl.org/disc-o#DispositionOutcome
:DispositionOutcome rdf:type owl:Class ;
                    rdfs:subClassOf gufo:Situation ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty [ owl:inverseOf gufo:broughtAbout
                                                     ] ;
                                      owl:someValuesFrom :DispositionManifestation
                                    ] .


###  http://purl.org/disc-o#DispositionOutput
:DispositionOutput rdf:type owl:Class ;
                   rdfs:subClassOf gufo:Object .


###  http://purl.org/disc-o#DispositionType
:DispositionType rdf:type owl:Class ;
                 rdfs:subClassOf <http://purl.com/cosy#MomentType> .


###  http://purl.org/disc-o#DispositionTypeByFunction
:DispositionTypeByFunction rdf:type owl:Class ;
                           rdfs:subClassOf :DispositionType .


###  http://purl.org/disc-o#DispositionTypeByLevel
:DispositionTypeByLevel rdf:type owl:Class ;
                        rdfs:subClassOf :DispositionType .


###  http://purl.org/disc-o#EmergentDisposition
:EmergentDisposition rdf:type owl:Class ;
                     rdfs:subClassOf :Disposition ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty gufo:inheresIn ;
                                       owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass gufo:FunctionalComplex
                                     ] ;
                     owl:disjointWith :ResultantDisposition .


###  http://purl.org/disc-o#EmergentDispositionManifestation
:EmergentDispositionManifestation rdf:type owl:Class ;
                                  rdfs:subClassOf :DispositionManifestation ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                                   ] ;
                                                    owl:someValuesFrom gufo:FunctionalComplex
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                   ] ;
                                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass :EmergentDisposition
                                                  ] .


###  http://purl.org/disc-o#EnablingDisposition
:EnablingDisposition rdf:type owl:Class ;
                     rdfs:subClassOf :InteractiveDisposition .


###  http://purl.org/disc-o#Interaction
:Interaction rdf:type owl:Class ;
             rdfs:subClassOf gufo:Event ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty [ owl:inverseOf gufo:contributedToTrigger
                                              ] ;
                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :InteractiveSituation
                             ] .


###  http://purl.org/disc-o#InteractiveDisposition
:InteractiveDisposition rdf:type owl:Class ;
                        rdfs:subClassOf :Disposition .


###  http://purl.org/disc-o#InteractiveDispositionManifestation
:InteractiveDispositionManifestation rdf:type owl:Class ;
                                     rdfs:subClassOf :DispositionManifestation ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                      ] ;
                                                       owl:someValuesFrom :InteractiveDisposition
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf gufo:contributedToTrigger
                                                                      ] ;
                                                       owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass :InteractiveSituation
                                                     ] .


###  http://purl.org/disc-o#InteractiveDispositionRole
:InteractiveDispositionRole rdf:type owl:Class ;
                            rdfs:subClassOf :DispositionType ,
                                            gufo:RoleMixin .


###  http://purl.org/disc-o#InteractiveObject
:InteractiveObject rdf:type owl:Class ;
                   rdfs:subClassOf gufo:Object ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty [ owl:inverseOf gufo:mediates
                                                    ] ;
                                     owl:someValuesFrom :InteractiveRelator
                                   ] .


###  http://purl.org/disc-o#InteractiveObjectType
:InteractiveObjectType rdf:type owl:Class ;
                       rdfs:subClassOf :ObjectType ;
                       rdfs:comment """A specialization of object type concerning objects that potentially can participate in a interaction, mediated by a relator, bearing specific interactive dispositions.

Example: A 'student' object who can play a role in a classroom interaction, bearing the disposition to 'learn'.
Reference: R. F. Calhau, J. P. A. Almeida, G. Guizzardi; Disc-O: An Ontology of Dispositions and their Interrelations within Systems (2025).
Link: http://purl.org/disc-o/paper"""@en ;
                       rdfs:label "InteractiveObjectType"@en .


###  http://purl.org/disc-o#InteractiveRelator
:InteractiveRelator rdf:type owl:Class ;
                    rdfs:subClassOf gufo:Relator ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty gufo:mediates ;
                                      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass :InteractiveObject
                                    ] .


###  http://purl.org/disc-o#InteractiveSituation
:InteractiveSituation rdf:type owl:Class ;
                      rdfs:subClassOf gufo:Situation .


###  http://purl.org/disc-o#InternalEvent
:InternalEvent rdf:type owl:Class ;
               rdfs:subClassOf gufo:Event .


###  http://purl.org/disc-o#JointManifestation
:JointManifestation rdf:type owl:Class ;
                    rdfs:subClassOf :InteractiveDispositionManifestation ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                     ] ;
                                      owl:someValuesFrom :ManifestationPartnerDisposition
                                    ] .


###  http://purl.org/disc-o#LoneDisposition
:LoneDisposition rdf:type owl:Class ;
                 rdfs:subClassOf :Disposition ;
                 owl:disjointWith :ReciprocalDisposition .


###  http://purl.org/disc-o#LoneManifestation
:LoneManifestation rdf:type owl:Class ;
                   rdfs:subClassOf :DispositionManifestation ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                    ] ;
                                     owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :LoneDisposition
                                   ] .


###  http://purl.org/disc-o#ManifestationContext
:ManifestationContext rdf:type owl:Class ;
                      rdfs:subClassOf gufo:Situation ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty gufo:historicallyDependsOn ;
                                        owl:someValuesFrom :DispositionOutcome
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty gufo:contributedToTrigger ;
                                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass :DispositionManifestation
                                      ] .


###  http://purl.org/disc-o#ManifestationPartnerDisposition
:ManifestationPartnerDisposition rdf:type owl:Class ;
                                 rdfs:subClassOf :InteractiveDisposition ,
                                                 :ReciprocalDisposition .


###  http://purl.org/disc-o#ObjectQuality
:ObjectQuality rdf:type owl:Class ;
               rdfs:subClassOf gufo:Quality ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <file:/Users/rodrigocalhau/Documents/VPProjects/null> ;
                                 owl:someValuesFrom :Disposition
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty gufo:inheresIn ;
                                 owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass gufo:Object
                               ] .


###  http://purl.org/disc-o#ObjectType
:ObjectType rdf:type owl:Class ;
            rdfs:subClassOf gufo:EndurantType .


###  http://purl.org/disc-o#ObjectTypeByLevel
:ObjectTypeByLevel rdf:type owl:Class ;
                   rdfs:subClassOf :ObjectType .


###  http://purl.org/disc-o#ParticularDisposition
:ParticularDisposition rdf:type owl:Class ;
                       rdfs:subClassOf :Disposition .


###  http://purl.org/disc-o#ParticularDispositionManifestation
:ParticularDispositionManifestation rdf:type owl:Class ;
                                    rdfs:subClassOf :DispositionManifestation ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                     ] ;
                                                      owl:someValuesFrom :ParticularDisposition
                                                    ] .


###  http://purl.org/disc-o#ReciprocalDisposition
:ReciprocalDisposition rdf:type owl:Class ;
                       rdfs:subClassOf :Disposition .


###  http://purl.org/disc-o#ResultantDisposition
:ResultantDisposition rdf:type owl:Class ;
                      rdfs:subClassOf :Disposition .


###  http://purl.org/disc-o#SimpleDisposition
:SimpleDisposition rdf:type owl:Class ;
                   rdfs:subClassOf :Disposition .


###  http://purl.org/disc-o#SubtractiveDisposition
:SubtractiveDisposition rdf:type owl:Class ;
                        rdfs:subClassOf :InteractiveDisposition .


###  http://purl.org/nemo/gufo#FunctionalComplex
gufo:FunctionalComplex rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty [ owl:inverseOf gufo:inheresIn
                                                        ] ;
                                         owl:someValuesFrom :EmergentDisposition
                                       ] .


###  http://purl.org/nemo/gufo#Participation
gufo:Participation rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty [ owl:inverseOf gufo:isEventProperPartOf
                                                    ] ;
                                     owl:someValuesFrom :Interaction
                                   ] .


